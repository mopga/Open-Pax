# Open-Pax Environment Variables
# Copy this file to .env and fill in your values

# MiniMax API Key (required)
# Get your key at https://platform.minimaxi.com
MINIMAX_API_KEY=your_api_key_here

# MiniMax API base URL (optional, default: https://api.minimax.io/v1)
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# LLM model name (optional, default: MiniMax-M2.5)
# LLM_MODEL=MiniMax-M2.5

# Server port (optional, default: 8000)
PORT=8000

# SQLite database path (optional, default: ./data/open-pax.db;
# used by tests to point at a temp DB)
# OPEN_PAX_DB_PATH=./data/open-pax.db
