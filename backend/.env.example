# Open-Pax Environment Variables
# Скопируй этот файл в .env и заполни свои значения

# MiniMax API (бесплатная подписка)
MINIMAX_API_KEY=your_api_key_here
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Или OpenAI (альтернатива)
# OPENAI_API_KEY=your_openai_key

# Database
DATABASE_URL=sqlite:///./pax.db
# Для PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/pax

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
